FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_ENABLED=true
AIML_MODEL=google/gemma-3-4b-it
AIML_EMBEDDING_MODEL=text-embedding-3-small
# Optional per-task model routing. Each falls back to AIML_MODEL when unset, so
# you can pin a stronger model on the reasoning agents and a cheaper one on the
# high-volume auxiliary tasks to stretch credits. Example:
#   AIML_REASONING_MODEL=google/gemini-2.5-flash
#   AIML_SALES_MODEL=gpt-4o-mini
#   AIML_NORMALIZE_MODEL=gpt-4o-mini
#   AIML_INTAKE_RISK_MODEL=gpt-4o-mini
#   AIML_DRIFT_MODEL=gpt-4o-mini
#   AIML_REPORT_MODEL=gpt-4o-mini
#   AIML_RERANK_MODEL=gpt-4o-mini
AIML_NORMALIZE_LIVE_LIMIT=20
AIML_SALES_LIVE_LIMIT=30
AIML_DRIFT_LIVE_LIMIT=30
AIML_DRIFT_ENABLE_LIVE=false
AIML_DRIFT_SCAN_ALL=false
AIML_INTAKE_RISK_LIVE_LIMIT=30
AIML_REPORT_LIVE_LIMIT=10
AIML_REASONING_LIVE_LIMIT=200
AIML_EMBEDDING_LIVE_LIMIT=200
AIML_RERANK_LIVE_LIMIT=200
FEATHERLESS_REVIEW_LIVE_LIMIT=30
HARDENING_NORMALIZE_LIMIT=4
HARDENING_INTAKE_RISK_LIMIT=4
HARDENING_SALES_LIMIT=4
HARDENING_DRIFT_ENABLE=true
HARDENING_DRIFT_LIMIT=4
HARDENING_REPORT_LIMIT=1
HARDENING_FEATHERLESS_LIMIT=6
BAND_MODE=lite
FEATHERLESS_MODE=lite
AIML_MODE=live
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_DEFAULT_ROOM_ID=
BAND_SERVICE_LIVE=false
BAND_SERVICE_HEARTBEAT_SECONDS=30
BANDGATE_HUMAN_WAIT_SECONDS=900
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
DEMO_MODE=lite
